{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "prinol-artfolio",
  "compatibility_date": "2026-04-22",
  "pages_build_output_dir": ".",
  "r2_buckets": [
    {
      "binding": "ART_BUCKET",
      "bucket_name": "prinol-artworks"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "a00a4e47-dc6d-4107-bd42-480b7c1d7b21"
    }
  ]
}
